table FACT_CONTRATOS
	lineageTag: 935e3490-4712-4635-8455-5c37ec244740

	measure 'Total Contratos' = COUNTROWS(FACT_CONTRATOS)
		formatString: 0
		lineageTag: 4480bbaf-fe70-4090-a611-6d2ece62d0f1

	measure 'Gasto Total' = SUM(FACT_CONTRATOS[IMPORTE_CON_IVA_EUR])
		formatString: #,0.00\ "€";-#,0.00\ "€";#,0.00\ "€"
		lineageTag: cb8cf2dd-fe50-4f53-8879-b88fb4cbae00

	measure 'Gasto Medio' = AVERAGE(FACT_CONTRATOS[IMPORTE_CON_IVA_EUR])
		formatString: #,0.00\ "€";-#,0.00\ "€";#,0.00\ "€"
		lineageTag: 6f78bbdf-be86-4529-bd66-d754d5ae811a

	measure 'Empresas Distintas' = DISTINCTCOUNT(FACT_CONTRATOS[NIF_CONTRATISTA])
		formatString: 0
		lineageTag: afa48f5e-4351-45f3-9858-aa045407b854

	measure 'Contratos Cerca del Limite' = CALCULATE(COUNTROWS(FACT_CONTRATOS), FACT_CONTRATOS[FLAG_LIMITE] = "cerca_del_limite")
		formatString: 0
		lineageTag: 1c4a4c17-c9ec-4577-8002-e2f866533a46

	measure '% Cerca del Limite' = DIVIDE([Contratos Cerca del Limite], [Total Contratos])
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: 9f61f9f6-e2c0-4118-90f3-7fc712c40a67

	measure 'Contratos con NIF Invalido' = CALCULATE(COUNTROWS(FACT_CONTRATOS), DIM_CONTRATISTA[NIF_VALIDO] = FALSE())
		formatString: 0
		lineageTag: 8deb84ba-5fae-4999-aad9-d54a005d8b20

